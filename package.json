{
  "name": "taglify",
  "version": "1.0.6",
  "description": "Synchronize generated content inside marker blocks in any text file.",
  "keywords": [
    "markers",
    "codegen",
    "sync",
    "readme",
    "text"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "devDependencies": {
    "@size-limit/file": "^11.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.0.0",
    "@types/bun": "latest",
    "@types/node": "^22.20.1",
    "prettier": "^3.0.0",
    "size-limit": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "author": "jayF0x",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "sync:roadmap": "bun run scripts/sync-roadmap.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:run": "bun test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "npm:deploy": "bash ./scripts/publish-npm.sh",
    "rm:stalepr": "git branch -vv | grep '\\[gone\\]' | awk '{print $1}' | xargs git branch -D",
    "size": "size-limit",
    "rkit:pull": "bunx repokit pull",
    "rkit:push": "bunx repokit push"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayf0x/taglify.git"
  },
  "homepage": "https://github.com/jayf0x/taglify#readme",
  "bugs": {
    "url": "https://github.com/jayf0x/taglify/issues"
  }
}
